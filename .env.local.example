# ─────────────────────────────────────────────────────────────
# BYM Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Firebase (client-side) ─────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only) ──────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# The private key value has newlines — wrap it in double-quotes and use \n
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Resend (email notifications) ──────────────────────────
# Get from: https://resend.com → API Keys (100 emails/day free)
RESEND_API_KEY=
EMAIL_FROM="BYM Studio <hello@bymstudio.co>"
EMAIL_REPLY_TO=hello@bymstudio.co

# ── Optional overrides ─────────────────────────────────────
# Override email recipient during local dev (so you don't email real users)
# EMAIL_DEV_OVERRIDE_TO=your@personal.email

# ─────────────────────────────────────────────────────────────
# SETUP STEPS:
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Enable Firestore (Native mode)
# 3. Enable Authentication → Email/Password
# 4. Enable Storage
# 5. Go to Project Settings → Your apps → Add a Web App → copy config above
# 6. Go to Project Settings → Service Accounts → generate private key → copy values above
# 7. (Optional) Create a free Resend account at https://resend.com
# 8. Set your first user as admin:
#    In Firestore → users collection → find your uid document → set role = "admin"
# ─────────────────────────────────────────────────────────────
