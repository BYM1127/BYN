# ─────────────────────────────────────────────────────────────
# BYM Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── MongoDB (Database) ───────────────────────────────────────
# Get this from MongoDB Atlas (Connection String)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.../bymstudio?retryWrites=true&w=majority

# ── NextAuth (Authentication) ────────────────────────────────
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET=
# During local development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Blob (Storage) ────────────────────────────────────
# Get this from your Vercel Project -> Storage -> Blob
BLOB_READ_WRITE_TOKEN=

# ── Resend (email notifications) ──────────────────────────
# Get from: https://resend.com → API Keys (100 emails/day free)
RESEND_API_KEY=
EMAIL_FROM="BYM Studio <hello@bymstudio.co>"
EMAIL_REPLY_TO=hello@bymstudio.co

# ── Optional overrides ─────────────────────────────────────
# Override email recipient during local dev (so you don't email real users)
# EMAIL_DEV_OVERRIDE_TO=your@personal.email

# ─────────────────────────────────────────────────────────────
# SETUP STEPS:
# 1. Create a MongoDB database (Atlas or local) and set MONGODB_URI.
# 2. Generate a NEXTAUTH_SECRET.
# 3. Create a Vercel project and provision a Blob store, set BLOB_READ_WRITE_TOKEN.
# 4. (Optional) Create a free Resend account at https://resend.com
# ─────────────────────────────────────────────────────────────
